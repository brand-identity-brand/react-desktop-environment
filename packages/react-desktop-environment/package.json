{
  "name": "react-desktop-environment",
  "version": "1.0.0",
  "description": "Headless window manager with a desktop compositor and replaceable React UI",
  "license": "ISC",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "src"
  ],
  "main": "./dist/react-desktop-environment.cjs",
  "module": "./dist/react-desktop-environment.js",
  "exports": {
    ".": {
      "development": "./src/index.js",
      "import": "./dist/react-desktop-environment.js",
      "require": "./dist/react-desktop-environment.cjs"
    },
    "./window-manager": {
      "development": "./src/window-manager/index.js",
      "import": "./dist/window-manager.js",
      "require": "./dist/window-manager.cjs"
    },
    "./window-manager/react": {
      "development": "./src/window-manager/react/index.js",
      "import": "./dist/window-manager-react.js",
      "require": "./dist/window-manager-react.cjs"
    },
    "./compositor": {
      "development": "./src/compositor/index.js",
      "import": "./dist/compositor.js",
      "require": "./dist/compositor.cjs"
    },
    "./ui": {
      "development": "./src/ui/index.js",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^22.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^4.3.4",
    "vitest": "^0.30.1"
  }
}
